 332:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** // MixColumns function mixes the columns of the state matrix
 333:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** static void MixColumns(void)
 334:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** {
 335:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   uint8_t i;
 336:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   uint8_t Tmp,Tm,t;
 337:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   for(i = 0; i < 4; ++i)
 338:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   {  
 339:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       #ifdef JITTER_2
 340:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       if (input_save[4*i] & 0x01) {
 341:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****         volatile int i = 0;
 342:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****         i += 1;
 343:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       }
 344:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       if (input_save[4*i] & 0x02) {
 345:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****         volatile int i = 0;
 346:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****         i += 1;
 347:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       }
 348:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       #endif
 349:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     t   = (*state)[i][0];
 350:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     Tmp = (*state)[i][0] ^ (*state)[i][1] ^ (*state)[i][2] ^ (*state)[i][3] ;
 351:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     Tm  = (*state)[i][0] ^ (*state)[i][1] ; Tm = xtime(Tm);  (*state)[i][0] ^= Tm ^ Tmp ;
 352:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     Tm  = (*state)[i][1] ^ (*state)[i][2] ; Tm = xtime(Tm);  (*state)[i][1] ^= Tm ^ Tmp ;
 353:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     Tm  = (*state)[i][2] ^ (*state)[i][3] ; Tm = xtime(Tm);  (*state)[i][2] ^= Tm ^ Tmp ;
 354:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     Tm  = (*state)[i][3] ^ t ;        Tm = xtime(Tm);  (*state)[i][3] ^= Tm ^ Tmp ;
 355:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   }
 356:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** }
 357:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** 
 358:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** // Multiply is used to multiply numbers in the field GF(2^8)
 359:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** #if MULTIPLY_AS_A_FUNCTION
 360:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** static uint8_t Multiply(uint8_t x, uint8_t y)
 361:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** {
 362:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   return (((y & 1) * x) ^
 363:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****        ((y>>1 & 1) * xtime(x)) ^
 364:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****        ((y>>2 & 1) * xtime(xtime(x))) ^
 365:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****        ((y>>3 & 1) * xtime(xtime(xtime(x)))) ^
 366:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****        ((y>>4 & 1) * xtime(xtime(xtime(xtime(x))))));
 367:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   }
 368:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** #else
 369:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** #define Multiply(x, y)                                \
 370:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       (  ((y & 1) * x) ^                              \
 371:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       ((y>>1 & 1) * xtime(x)) ^                       \
 372:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       ((y>>2 & 1) * xtime(xtime(x))) ^                \
 373:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       ((y>>3 & 1) * xtime(xtime(xtime(x)))) ^         \
 374:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****       ((y>>4 & 1) * xtime(xtime(xtime(xtime(x))))))   \
 375:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** 
 376:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** #endif
 377:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** 
 378:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** // MixColumns function mixes the columns of the state matrix.
 379:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** // The method used to multiply may be difficult to understand for the inexperienced.
 380:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** // Please use the references to gain more information.
 381:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** static void InvMixColumns(void)
 382:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** {
 383:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   int i;
 384:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   uint8_t a,b,c,d;
 385:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   for(i=0;i<4;++i)
 386:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   { 
 387:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     a = (*state)[i][0];
 388:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     b = (*state)[i][1];
 389:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     c = (*state)[i][2];
 390:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     d = (*state)[i][3];
 391:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** 
 392:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     (*state)[i][0] = Multiply(a, 0x0e) ^ Multiply(b, 0x0b) ^ Multiply(c, 0x0d) ^ Multiply(d, 0x09);
 393:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     (*state)[i][1] = Multiply(a, 0x09) ^ Multiply(b, 0x0e) ^ Multiply(c, 0x0b) ^ Multiply(d, 0x0d);
 394:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     (*state)[i][2] = Multiply(a, 0x0d) ^ Multiply(b, 0x09) ^ Multiply(c, 0x0e) ^ Multiply(d, 0x0b);
 395:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     (*state)[i][3] = Multiply(a, 0x0b) ^ Multiply(b, 0x0d) ^ Multiply(c, 0x09) ^ Multiply(d, 0x0e);
 396:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   }
 397:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** }
