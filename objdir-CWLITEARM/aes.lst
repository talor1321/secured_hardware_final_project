 469:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** static void InvCipher(void)
 470:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** {
 471:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   uint8_t round=0;
 472:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** 
 473:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   // Add the First round key to the state before starting the rounds.
 474:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   AddRoundKey(Nr); 
 475:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** 
 476:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   // There will be Nr rounds.
 477:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   // The first Nr-1 rounds are identical.
 478:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   // These Nr-1 rounds are executed in the loop below.
 479:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   for(round=Nr-1;round>0;round--)
 480:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   {
 481:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     InvShiftRows();
 482:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     InvSubBytes();
 483:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     AddRoundKey(round);
 484:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****     InvMixColumns();
 485:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   }
 486:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   
 487:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   // The last round is given below.
 488:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   // The MixColumns function is not here in the last round.
 489:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   InvShiftRows();
 490:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   InvSubBytes();
 491:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   AddRoundKey(0);
 492:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** }
