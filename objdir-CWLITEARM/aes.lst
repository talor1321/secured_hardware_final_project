 119:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** // The round constant word array, Rcon[i], contains the values given by 
 120:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** // x to th e power (i-1) being powers of x (x is denoted as {02}) in the field GF(2^8)
 121:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** // Note that i starts at 1, not 0).
 122:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** AES_CONST_VAR uint8_t Rcon[11] = {
 123:../../firmware/mcu/crypto/tiny-AES128-C/aes.c ****   0x8d, 0x01, 0x02, 0x04, 0x08, 0x10, 0x20, 0x40, 0x80, 0x1b, 0x36
 124:../../firmware/mcu/crypto/tiny-AES128-C/aes.c **** };
