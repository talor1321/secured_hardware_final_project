  74:c_code.c      **** static uint32_t step_plain_v2(uint8_t num_steps, uint32_t polynomial);
  75:c_code.c      **** static uint32_t step_plain_v3(uint8_t num_steps, uint32_t polynomial);
  76:c_code.c      **** 
  77:c_code.c      **** static uint32_t step_plain(uint8_t num_steps, uint32_t polynomial)
  78:c_code.c      **** {
  79:c_code.c      ****     return step_plain_v3(num_steps, polynomial);
  80:c_code.c      **** }
  81:c_code.c      **** 
  82:c_code.c      **** static uint32_t step_plain_v3(uint8_t num_steps, uint32_t polynomial)
  83:c_code.c      **** {
  84:c_code.c      ****     uint32_t lsb, temp, garbage; 
  85:c_code.c      ****     
  86:c_code.c      ****     trigger_high();
  87:c_code.c      **** 
  88:c_code.c      ****     __asm__ volatile (
  89:c_code.c      ****         "cmp %[steps], #0 \n\t"               
  90:c_code.c      ****         "beq 2f \n"                           
  91:c_code.c      ****         "1: \n\t"                             
  92:c_code.c      ****         
  93:c_code.c      ****         // 1. Extract LSB and shift state right
  94:c_code.c      ****         "and %[lsb], %[state], #1 \n\t"       
  95:c_code.c      ****         "lsr %[state], %[state], #1 \n\t"     
  96:c_code.c      ****         
  97:c_code.c      ****         // 2. Unconditional XOR into a temporary register
  98:c_code.c      ****         "eor %[temp], %[state], %[poly] \n\t" 
  99:c_code.c      ****         
 100:c_code.c      ****         // 3. Register routing based on LSB
 101:c_code.c      ****         "cmp %[lsb], #1 \n\t"                 // Compare LSB to 1
 102:c_code.c      ****         "ite eq \n\t"                         // If-Then-Else block (Condition: Equal)
 103:c_code.c      ****         "moveq %[state], %[temp] \n\t"        // THEN (LSB=1): Copy temp to state
 104:c_code.c      ****         "movne %[garb], %[temp] \n\t"         // ELSE (LSB=0): Copy temp to garbage
 105:c_code.c      ****         
 106:c_code.c      ****         // --- Loop Control ---
 107:c_code.c      ****         "subs %[steps], %[steps], #1 \n\t"    
 108:c_code.c      ****         "bne 1b \n"                           
 109:c_code.c      ****         "2: \n"                               
 110:c_code.c      ****         
 111:c_code.c      ****         : [state] "+r" (g_lfsr_state),
 112:c_code.c      ****           [steps] "+r" (num_steps),
 113:c_code.c      ****           [lsb]   "=&r" (lsb),
 114:c_code.c      ****           [temp]  "=&r" (temp),
 115:c_code.c      ****           [garb]  "=&r" (garbage)
 116:c_code.c      ****         : [poly]  "r"  (polynomial)
 117:c_code.c      ****         : "cc"                                
 118:c_code.c      ****     );
 119:c_code.c      **** 
 120:c_code.c      ****     trigger_low();
 121:c_code.c      ****     return g_lfsr_state;
 122:c_code.c      **** }
 123:c_code.c      **** 
 124:c_code.c      **** static uint32_t step_plain_v2(uint8_t num_steps, uint32_t polynomial)
 125:c_code.c      **** {
 126:c_code.c      ****     uint32_t mask; 
 127:c_code.c      ****     
 128:c_code.c      ****     trigger_high();
 129:c_code.c      **** 
 130:c_code.c      ****     __asm__ volatile (
 131:c_code.c      ****         "cmp %[steps], #0 \n\t"               
 132:c_code.c      ****         "beq 2f \n"                           
 133:c_code.c      ****         "1: \n\t"                             
 134:c_code.c      ****         
 135:c_code.c      ****         // --- Data Processing (No 's' -> No Flag Updates) ---
 136:c_code.c      ****         "and %[mask], %[state], #1 \n\t"      // Extract LSB
 137:c_code.c      ****         "lsr %[state], %[state], #1 \n\t"     // Shift state right
 138:c_code.c      ****         "rsb %[mask], %[mask], #0 \n\t"       // Mask expansion (0 - LSB)
 139:c_code.c      ****         "and %[mask], %[mask], %[poly] \n\t"  // Mask the polynomial
 140:c_code.c      ****         "eor %[state], %[state], %[mask] \n\t"// Apply XOR feedback
 141:c_code.c      ****         
 142:c_code.c      ****         // --- Loop Control (Keep 's' -> Updates Z flag) ---
 143:c_code.c      ****         "subs %[steps], %[steps], #1 \n\t"    // Decrement counter
 144:c_code.c      ****         "bne 1b \n"                           // Branch if Z flag != 1
 145:c_code.c      ****         "2: \n"                               
 146:c_code.c      ****         
 147:c_code.c      ****         : [state] "+r" (g_lfsr_state),
 148:c_code.c      ****           [steps] "+r" (num_steps),
 149:c_code.c      ****           [mask]  "=&r" (mask)                
 150:c_code.c      ****         : [poly]  "r"  (polynomial)
 151:c_code.c      ****         : "cc"                                // We still clobber CC because of subs/cmp
 152:c_code.c      ****     );
 153:c_code.c      **** 
 154:c_code.c      ****     trigger_low();
 155:c_code.c      ****     return g_lfsr_state;
 156:c_code.c      **** }
 157:c_code.c      **** 
 158:c_code.c      **** static uint32_t step_plain_v1(uint8_t num_steps, uint32_t polynomial)
 159:c_code.c      **** {
 160:c_code.c      ****     trigger_high();
 161:c_code.c      **** 
 162:c_code.c      ****     __asm__ volatile (
 163:c_code.c      ****         "cmp %[steps], #0 \n\t"               // Check if num_steps is 0
 164:c_code.c      ****         "beq 2f \n"                           // If 0, jump forward to label 2
 165:c_code.c      ****         "1: \n\t"                             // Loop start
 166:c_code.c      ****         "lsrs %[state], %[state], #1 \n\t"    // Shift state right by 1. LSB goes into Carry flag
 167:c_code.c      ****         "bcc 3f \n\t"                         // If Carry is Clear (LSB was 0), skip the XOR
 168:c_code.c      ****         "eors %[state], %[state], %[poly] \n" // XOR state with polynomial
 169:c_code.c      ****         "3: \n\t"
 170:c_code.c      ****         "subs %[steps], %[steps], #1 \n\t"    // Decrement steps
 171:c_code.c      ****         "bne 1b \n"                           // If steps != 0, branch backward to label 1
 172:c_code.c      ****         "2: \n"                               // Loop end
 173:c_code.c      ****         
 174:c_code.c      ****         // --- Output Operands ---
 175:c_code.c      ****         : [state] "+r" (g_lfsr_state),        // '+' means read and write
 176:c_code.c      ****           [steps] "+r" (num_steps)
 177:c_code.c      ****           
 178:c_code.c      ****         // --- Input Operands ---
 179:c_code.c      ****         : [poly]  "r"  (polynomial)           // 'r' means put in a general register
 180:c_code.c      ****         
 181:c_code.c      ****         // --- Clobbers ---
 182:c_code.c      ****         : "cc"                                // Tells compiler we modify condition flags
 183:c_code.c      ****     );
 184:c_code.c      **** 
 185:c_code.c      ****     trigger_low();
 186:c_code.c      ****     return g_lfsr_state;
 187:c_code.c      **** }
 188:c_code.c      **** 
 189:c_code.c      **** static uint32_t step_shuffled(uint8_t num_steps, uint32_t polynomial)
 190:c_code.c      **** {
 191:c_code.c      ****     uint8_t i;
 192:c_code.c      ****     trigger_high();
 193:c_code.c      ****     for(i = 0; i < num_steps; i++) {
 194:c_code.c      ****         uint32_t lsb = g_lfsr_state & 1u;
 195:c_code.c      ****         g_lfsr_state = (g_lfsr_state >> 1) ^ (polynomial & (0u - lsb));
 196:c_code.c      ****     }
 197:c_code.c      ****     trigger_low();
 198:c_code.c      ****     return g_lfsr_state;
 199:c_code.c      **** }
 200:c_code.c      **** 
 201:c_code.c      **** static uint32_t step_masked(uint8_t num_steps, uint32_t polynomial)
 202:c_code.c      **** {
 203:c_code.c      ****     uint8_t i;
 204:c_code.c      ****     trigger_high();
 205:c_code.c      ****     for(i = 0; i < num_steps; i++) {
 206:c_code.c      ****         uint32_t lsb_state = g_lfsr_state & 1u;
 207:c_code.c      ****         uint32_t lsb_mask = g_lfsr_mask & 1u;
 208:c_code.c      ****         g_lfsr_state = (g_lfsr_state >> 1) ^ (polynomial * lsb_state);
 209:c_code.c      ****         g_lfsr_mask = (g_lfsr_mask >> 1) ^ (polynomial * lsb_mask);
 210:c_code.c      ****     }
 211:c_code.c      ****     trigger_low();
 212:c_code.c      ****     return g_lfsr_state ^ g_lfsr_mask;
 213:c_code.c      **** }
 214:c_code.c      **** 
 215:c_code.c      **** static uint32_t step_masked_shuffled(uint8_t num_steps, uint32_t polynomial)
 216:c_code.c      **** {
 217:c_code.c      ****     uint8_t i;
 218:c_code.c      ****     trigger_high();
 219:c_code.c      ****     for(i = 0; i < num_steps; i++) {
 220:c_code.c      ****         uint32_t lsb_state = g_lfsr_state & 1u;
 221:c_code.c      ****         uint32_t lsb_mask = g_lfsr_mask & 1u;
 222:c_code.c      ****         g_lfsr_state = (g_lfsr_state >> 1) ^ (polynomial & (0u - lsb_state));
 223:c_code.c      ****         g_lfsr_mask = (g_lfsr_mask >> 1) ^ (polynomial & (0u - lsb_mask));
 224:c_code.c      ****     }
 225:c_code.c      ****     trigger_low();
 226:c_code.c      ****     return g_lfsr_state ^ g_lfsr_mask;
 227:c_code.c      **** }
 228:c_code.c      **** 
 229:c_code.c      **** static uint32_t step_masked_interleaved_asm(uint8_t num_steps, uint32_t polynomial)
 230:c_code.c      **** {
 231:c_code.c      ****     uint32_t lsb, mask1_val, mask2_val, mask3_val, temp, poly_val;
 232:c_code.c      **** 
 233:c_code.c      ****     /* Precompute interleaved polynomial (outside the sensitive region) */
 234:c_code.c      ****     compute_interleaved_poly(polynomial);
 235:c_code.c      **** 
 236:c_code.c      ****     trigger_high();
 237:c_code.c      **** 
 238:c_code.c      ****     __asm__ volatile (
 239:c_code.c      ****         "cmp %[steps], #0 \n\t"
 240:c_code.c      ****         "beq 2f \n"
 241:c_code.c      ****         "1: \n\t"
 242:c_code.c      **** 
 243:c_code.c      ****         /* Step A: Extract LSB group (3 bits from bottom of reg0) */
 244:c_code.c      ****         "and %[lsb], %[r0], #7 \n\t"
 245:c_code.c      **** 
 246:c_code.c      ****         /* Step B: Multi-register right shift by 3 */
 247:c_code.c      ****         /* reg0 = (reg0 >> 3) | ((reg1 & 7) << 21) */
 248:c_code.c      ****         "lsr %[r0], %[r0], #3 \n\t"
 249:c_code.c      ****         "and %[temp], %[r1], #7 \n\t"
 250:c_code.c      ****         "orr %[r0], %[r0], %[temp], lsl #21 \n\t"
 251:c_code.c      **** 
 252:c_code.c      ****         /* reg1 = (reg1 >> 3) | ((reg2 & 7) << 21) */
 253:c_code.c      ****         "lsr %[r1], %[r1], #3 \n\t"
 254:c_code.c      ****         "and %[temp], %[r2], #7 \n\t"
 255:c_code.c      ****         "orr %[r1], %[r1], %[temp], lsl #21 \n\t"
 256:c_code.c      **** 
 257:c_code.c      ****         /* reg2 = (reg2 >> 3) | ((reg3 & 7) << 21) */
 258:c_code.c      ****         "lsr %[r2], %[r2], #3 \n\t"
 259:c_code.c      ****         "and %[temp], %[r3], #7 \n\t"
 260:c_code.c      ****         "orr %[r2], %[r2], %[temp], lsl #21 \n\t"
 261:c_code.c      **** 
 262:c_code.c      ****         /* reg3 = reg3 >> 3 */
 263:c_code.c      ****         "lsr %[r3], %[r3], #3 \n\t"
 264:c_code.c      **** 
 265:c_code.c      ****         /* Step C: Expand each share LSB to a full 32-bit mask */
 266:c_code.c      ****         /* mask1 = -(lsb & 1)  : 0x00000000 or 0xFFFFFFFF */
 267:c_code.c      ****         "and %[mask1], %[lsb], #1 \n\t"
 268:c_code.c      ****         "rsb %[mask1], %[mask1], #0 \n\t"
 269:c_code.c      **** 
 270:c_code.c      ****         /* mask2 = -((lsb >> 1) & 1) */
 271:c_code.c      ****         "ubfx %[mask2], %[lsb], #1, #1 \n\t"
 272:c_code.c      ****         "rsb %[mask2], %[mask2], #0 \n\t"
 273:c_code.c      **** 
 274:c_code.c      ****         /* mask3 = -((lsb >> 2) & 1) */
 275:c_code.c      ****         "ubfx %[mask3], %[lsb], #2, #1 \n\t"
 276:c_code.c      ****         "rsb %[mask3], %[mask3], #0 \n\t"
 277:c_code.c      **** 
 278:c_code.c      ****         /* Step D: Polynomial feedback for each register                  */
 279:c_code.c      ****         /* feedback = (poly & mask1) | ((poly<<1) & mask2) | ((poly<<2) & mask3) */
 280:c_code.c      ****         /* [lsb] is reused as the feedback accumulator (original lsb no longer needed) */
 281:c_code.c      **** 
 282:c_code.c      ****         /* ---- reg0 feedback ---- */
 283:c_code.c      ****         "ldr %[poly], [%[pptr], #0] \n\t"
 284:c_code.c      ****         "and %[lsb], %[poly], %[mask1] \n\t"
 285:c_code.c      ****         "and %[temp], %[mask2], %[poly], lsl #1 \n\t"
 286:c_code.c      ****         "orr %[lsb], %[lsb], %[temp] \n\t"
 287:c_code.c      ****         "and %[temp], %[mask3], %[poly], lsl #2 \n\t"
 288:c_code.c      ****         "orr %[lsb], %[lsb], %[temp] \n\t"
 289:c_code.c      ****         "eor %[r0], %[r0], %[lsb] \n\t"
 290:c_code.c      **** 
 291:c_code.c      ****         /* ---- reg1 feedback ---- */
 292:c_code.c      ****         "ldr %[poly], [%[pptr], #4] \n\t"
 293:c_code.c      ****         "and %[lsb], %[poly], %[mask1] \n\t"
 294:c_code.c      ****         "and %[temp], %[mask2], %[poly], lsl #1 \n\t"
 295:c_code.c      ****         "orr %[lsb], %[lsb], %[temp] \n\t"
 296:c_code.c      ****         "and %[temp], %[mask3], %[poly], lsl #2 \n\t"
 297:c_code.c      ****         "orr %[lsb], %[lsb], %[temp] \n\t"
 298:c_code.c      ****         "eor %[r1], %[r1], %[lsb] \n\t"
 299:c_code.c      **** 
 300:c_code.c      ****         /* ---- reg2 feedback ---- */
 301:c_code.c      ****         "ldr %[poly], [%[pptr], #8] \n\t"
 302:c_code.c      ****         "and %[lsb], %[poly], %[mask1] \n\t"
 303:c_code.c      ****         "and %[temp], %[mask2], %[poly], lsl #1 \n\t"
 304:c_code.c      ****         "orr %[lsb], %[lsb], %[temp] \n\t"
 305:c_code.c      ****         "and %[temp], %[mask3], %[poly], lsl #2 \n\t"
 306:c_code.c      ****         "orr %[lsb], %[lsb], %[temp] \n\t"
 307:c_code.c      ****         "eor %[r2], %[r2], %[lsb] \n\t"
 308:c_code.c      **** 
 309:c_code.c      ****         /* ---- reg3 feedback ---- */
 310:c_code.c      ****         "ldr %[poly], [%[pptr], #12] \n\t"
 311:c_code.c      ****         "and %[lsb], %[poly], %[mask1] \n\t"
 312:c_code.c      ****         "and %[temp], %[mask2], %[poly], lsl #1 \n\t"
 313:c_code.c      ****         "orr %[lsb], %[lsb], %[temp] \n\t"
 314:c_code.c      ****         "and %[temp], %[mask3], %[poly], lsl #2 \n\t"
 315:c_code.c      ****         "orr %[lsb], %[lsb], %[temp] \n\t"
 316:c_code.c      ****         "eor %[r3], %[r3], %[lsb] \n\t"
 317:c_code.c      **** 
 318:c_code.c      ****         /* Step E: Loop control */
 319:c_code.c      ****         "subs %[steps], %[steps], #1 \n\t"
 320:c_code.c      ****         "bne 1b \n"
 321:c_code.c      ****         "2: \n"
 322:c_code.c      **** 
 323:c_code.c      ****         : [r0]    "+r" (g_masked_state[0]),
 324:c_code.c      ****           [r1]    "+r" (g_masked_state[1]),
 325:c_code.c      ****           [r2]    "+r" (g_masked_state[2]),
 326:c_code.c      ****           [r3]    "+r" (g_masked_state[3]),
 327:c_code.c      ****           [steps] "+r" (num_steps),
 328:c_code.c      ****           [lsb]   "=&r" (lsb),
 329:c_code.c      ****           [mask1] "=&r" (mask1_val),
 330:c_code.c      ****           [mask2] "=&r" (mask2_val),
 331:c_code.c      ****           [mask3] "=&r" (mask3_val),
 332:c_code.c      ****           [temp]  "=&r" (temp),
 333:c_code.c      ****           [poly]  "=&r" (poly_val)
 334:c_code.c      ****         : [pptr]  "r"  (g_interleaved_poly)
 335:c_code.c      ****         : "cc", "memory"
 336:c_code.c      ****     );
 337:c_code.c      **** 
 338:c_code.c      ****     trigger_low();
 339:c_code.c      **** 
 340:c_code.c      ****     return collapse_shares();
 341:c_code.c      **** }
 342:c_code.c      **** 
 343:c_code.c      **** #define FB_R0 \
 344:c_code.c      ****     "ldr %[poly], [%[pptr], #0] \n\t" \
 345:c_code.c      ****     "and %[lsb], %[poly], %[t1_m1] \n\t" \
 346:c_code.c      ****     "and %[temp], %[t2_m2], %[poly], lsl #1 \n\t" \
 347:c_code.c      ****     "orr %[lsb], %[lsb], %[temp] \n\t" \
 348:c_code.c      ****     "and %[temp], %[t3_m3], %[poly], lsl #2 \n\t" \
 349:c_code.c      ****     "orr %[lsb], %[lsb], %[temp] \n\t" \
 350:c_code.c      ****     "eor %[r0], %[r0], %[lsb] \n\t"
 351:c_code.c      **** 
 352:c_code.c      **** #define FB_R1 \
 353:c_code.c      ****     "ldr %[poly], [%[pptr], #4] \n\t" \
 354:c_code.c      ****     "and %[lsb], %[poly], %[t1_m1] \n\t" \
 355:c_code.c      ****     "and %[temp], %[t2_m2], %[poly], lsl #1 \n\t" \
 356:c_code.c      ****     "orr %[lsb], %[lsb], %[temp] \n\t" \
 357:c_code.c      ****     "and %[temp], %[t3_m3], %[poly], lsl #2 \n\t" \
 358:c_code.c      ****     "orr %[lsb], %[lsb], %[temp] \n\t" \
 359:c_code.c      ****     "eor %[r1], %[r1], %[lsb] \n\t"
 360:c_code.c      **** 
 361:c_code.c      **** #define FB_R2 \
 362:c_code.c      ****     "ldr %[poly], [%[pptr], #8] \n\t" \
 363:c_code.c      ****     "and %[lsb], %[poly], %[t1_m1] \n\t" \
 364:c_code.c      ****     "and %[temp], %[t2_m2], %[poly], lsl #1 \n\t" \
 365:c_code.c      ****     "orr %[lsb], %[lsb], %[temp] \n\t" \
 366:c_code.c      ****     "and %[temp], %[t3_m3], %[poly], lsl #2 \n\t" \
 367:c_code.c      ****     "orr %[lsb], %[lsb], %[temp] \n\t" \
 368:c_code.c      ****     "eor %[r2], %[r2], %[lsb] \n\t"
 369:c_code.c      **** 
 370:c_code.c      **** #define FB_R3 \
 371:c_code.c      ****     "ldr %[poly], [%[pptr], #12] \n\t" \
 372:c_code.c      ****     "and %[lsb], %[poly], %[t1_m1] \n\t" \
 373:c_code.c      ****     "and %[temp], %[t2_m2], %[poly], lsl #1 \n\t" \
 374:c_code.c      ****     "orr %[lsb], %[lsb], %[temp] \n\t" \
 375:c_code.c      ****     "and %[temp], %[t3_m3], %[poly], lsl #2 \n\t" \
 376:c_code.c      ****     "orr %[lsb], %[lsb], %[temp] \n\t" \
 377:c_code.c      ****     "eor %[r3], %[r3], %[lsb] \n\t"
 378:c_code.c      **** 
 379:c_code.c      **** static uint32_t step_masked_interleaved_shuffled_asm(uint8_t num_steps, uint32_t polynomial)
 380:c_code.c      **** {
 381:c_code.c      ****     uint32_t lsb, t1_m1, t2_m2, t3_m3, temp, poly_val;
 382:c_code.c      ****     uint32_t rng = g_shuffle_rng_state;
 383:c_code.c      **** 
 384:c_code.c      ****     compute_interleaved_poly(polynomial);
 385:c_code.c      ****     trigger_high();
 386:c_code.c      **** 
 387:c_code.c      ****     __asm__ volatile (
 388:c_code.c      ****         "cmp %[steps], #0 \n\t"
 389:c_code.c      ****         "beq 99f \n"
 390:c_code.c      ****         "1: \n\t"
 391:c_code.c      **** 
 392:c_code.c      ****         /* Extract LSB group */
 393:c_code.c      ****         "and %[lsb], %[r0], #7 \n\t"
 394:c_code.c      **** 
 395:c_code.c      ****         /* Extract boundary bits (pre-extraction breaks strict dependencies) */
 396:c_code.c      ****         "and %[t1_m1], %[r1], #7 \n\t"
 397:c_code.c      ****         "and %[t2_m2], %[r2], #7 \n\t"
 398:c_code.c      ****         "and %[t3_m3], %[r3], #7 \n\t"
 399:c_code.c      **** 
 400:c_code.c      ****         /* Advance RNG (xorshift32) */
 401:c_code.c      ****         "eor %[rng], %[rng], %[rng], lsl #13 \n\t"
 402:c_code.c      ****         "eor %[rng], %[rng], %[rng], lsr #17 \n\t"
 403:c_code.c      ****         "eor %[rng], %[rng], %[rng], lsl #5 \n\t"
 404:c_code.c      **** 
 405:c_code.c      ****         /* Shuffled Shifts Selector (bits 0,1) */
 406:c_code.c      ****         "and %[temp], %[rng], #3 \n\t"
 407:c_code.c      ****         "cmp %[temp], #0 \n\t"
 408:c_code.c      ****         "beq 10f \n\t"
 409:c_code.c      ****         "cmp %[temp], #1 \n\t"
 410:c_code.c      ****         "beq 11f \n\t"
 411:c_code.c      ****         "cmp %[temp], #2 \n\t"
 412:c_code.c      ****         "beq 12f \n\t"
 413:c_code.c      ****         "b 13f \n\t"
 414:c_code.c      **** 
 415:c_code.c      ****         "10: \n\t" /* Pad: 5 NOPs to equalize cycle count with branch 13f */
 416:c_code.c      ****         "nop; nop; nop; nop; nop \n\t"
 417:c_code.c      ****         "lsr %[r0], %[r0], #3 \n\t" "orr %[r0], %[r0], %[t1_m1], lsl #21 \n\t"
 418:c_code.c      ****         "lsr %[r1], %[r1], #3 \n\t" "orr %[r1], %[r1], %[t2_m2], lsl #21 \n\t"
 419:c_code.c      ****         "lsr %[r2], %[r2], #3 \n\t" "orr %[r2], %[r2], %[t3_m3], lsl #21 \n\t"
 420:c_code.c      ****         "lsr %[r3], %[r3], #3 \n\t"
 421:c_code.c      ****         "b 20f \n\t"
 422:c_code.c      **** 
 423:c_code.c      ****         "11: \n\t" /* Pad: 3 NOPs */
 424:c_code.c      ****         "nop; nop; nop \n\t"
 425:c_code.c      ****         "lsr %[r1], %[r1], #3 \n\t" "orr %[r1], %[r1], %[t2_m2], lsl #21 \n\t"
 426:c_code.c      ****         "lsr %[r2], %[r2], #3 \n\t" "orr %[r2], %[r2], %[t3_m3], lsl #21 \n\t"
 427:c_code.c      ****         "lsr %[r3], %[r3], #3 \n\t"
 428:c_code.c      ****         "lsr %[r0], %[r0], #3 \n\t" "orr %[r0], %[r0], %[t1_m1], lsl #21 \n\t"
 429:c_code.c      ****         "b 20f \n\t"
 430:c_code.c      **** 
 431:c_code.c      ****         "12: \n\t" /* Pad: 1 NOP */
 432:c_code.c      ****         "nop \n\t"
 433:c_code.c      ****         "lsr %[r2], %[r2], #3 \n\t" "orr %[r2], %[r2], %[t3_m3], lsl #21 \n\t"
 434:c_code.c      ****         "lsr %[r3], %[r3], #3 \n\t"
 435:c_code.c      ****         "lsr %[r0], %[r0], #3 \n\t" "orr %[r0], %[r0], %[t1_m1], lsl #21 \n\t"
 436:c_code.c      ****         "lsr %[r1], %[r1], #3 \n\t" "orr %[r1], %[r1], %[t2_m2], lsl #21 \n\t"
 437:c_code.c      ****         "b 20f \n\t"
 438:c_code.c      **** 
 439:c_code.c      ****         "13: \n\t" /* No padding needed */
 440:c_code.c      ****         "lsr %[r3], %[r3], #3 \n\t"
 441:c_code.c      ****         "lsr %[r0], %[r0], #3 \n\t" "orr %[r0], %[r0], %[t1_m1], lsl #21 \n\t"
 442:c_code.c      ****         "lsr %[r1], %[r1], #3 \n\t" "orr %[r1], %[r1], %[t2_m2], lsl #21 \n\t"
 443:c_code.c      ****         "lsr %[r2], %[r2], #3 \n\t" "orr %[r2], %[r2], %[t3_m3], lsl #21 \n\t"
 444:c_code.c      ****         "b 20f \n\t"
 445:c_code.c      **** 
 446:c_code.c      ****         "20: \n\t"
 447:c_code.c      ****         /* --- Shifts Done --- */
 448:c_code.c      **** 
 449:c_code.c      ****         /* Mask expansion (we re-use t1_m1 etc. to hold expanded masks) */
 450:c_code.c      ****         "and %[t1_m1], %[lsb], #1 \n\t"
 451:c_code.c      ****         "rsb %[t1_m1], %[t1_m1], #0 \n\t"
 452:c_code.c      ****         "ubfx %[t2_m2], %[lsb], #1, #1 \n\t"
 453:c_code.c      ****         "rsb %[t2_m2], %[t2_m2], #0 \n\t"
 454:c_code.c      ****         "ubfx %[t3_m3], %[lsb], #2, #1 \n\t"
 455:c_code.c      ****         "rsb %[t3_m3], %[t3_m3], #0 \n\t"
 456:c_code.c      **** 
 457:c_code.c      ****         /* Shuffled Feedback Selector (bits 2,3) */
