  40:c_code.c      **** static void expand_seed_to_shares(uint32_t seed, uint32_t mask1, uint32_t mask2)
  41:c_code.c      **** {
  42:c_code.c      ****     int j, i;
  43:c_code.c      ****     for (j = 0; j < 4; j++) {
  44:c_code.c      ****         g_masked_state[j] = 0;
  45:c_code.c      ****         for (i = 0; i < 8; i++) {
  46:c_code.c      ****             int bit_idx = j * 8 + i;
  47:c_code.c      ****             uint32_t s1 = (mask1 >> bit_idx) & 1;
  48:c_code.c      ****             uint32_t s2 = (mask2 >> bit_idx) & 1;
  49:c_code.c      ****             uint32_t s3 = ((seed >> bit_idx) & 1) ^ s1 ^ s2;
  50:c_code.c      ****             int pos = i * 3;
  51:c_code.c      ****             g_masked_state[j] |= (s1 << pos) | (s2 << (pos + 1)) | (s3 << (pos + 2));
  52:c_code.c      ****         }
  53:c_code.c      ****     }
  54:c_code.c      **** }
