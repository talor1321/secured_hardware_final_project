 949:../../firmware/mcu/hal//stm32f3/stm32f3_hal_lowlevel.c ****   /* Check if the Receiver is enabled */
 950:../../firmware/mcu/hal//stm32f3/stm32f3_hal_lowlevel.c ****   if((huart->Instance->CR1 & USART_CR1_RE) == USART_CR1_RE)
 951:../../firmware/mcu/hal//stm32f3/stm32f3_hal_lowlevel.c ****   {
 952:../../firmware/mcu/hal//stm32f3/stm32f3_hal_lowlevel.c ****     /* Wait until REACK flag is set */
 953:../../firmware/mcu/hal//stm32f3/stm32f3_hal_lowlevel.c ****     if(UART_WaitOnFlagUntilTimeout(huart, USART_ISR_REACK, RESET, tickstart, HAL_UART_TIMEOUT_VALUE
 954:../../firmware/mcu/hal//stm32f3/stm32f3_hal_lowlevel.c ****     {
