 310:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Get FPSCR
 311:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Returns the current value of the Floating Point Status/Control register.
 312:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \return               Floating Point Status/Control register value
 313:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
 314:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__( ( always_inline ) ) __STATIC_INLINE uint32_t __get_FPSCR(void)
 315:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 316:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #if (__FPU_PRESENT == 1U) && (__FPU_USED == 1U)
 317:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   uint32_t result;
 318:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 319:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   /* Empty asm statement works as a scheduling barrier */
 320:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("");
 321:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("VMRS %0, fpscr" : "=r" (result) );
 322:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("");
 323:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   return(result);
 324:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #else
 325:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****    return(0);
 326:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #endif
 327:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 328:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 329:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 330:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 331:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Set FPSCR
