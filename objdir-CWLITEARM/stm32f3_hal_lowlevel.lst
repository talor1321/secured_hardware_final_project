 373:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__((always_inline)) __STATIC_INLINE void __NOP(void)
 374:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 375:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("nop");
 376:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 377:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 378:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 379:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 380:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Wait For Interrupt
 381:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Wait For Interrupt is a hint instruction that suspends execution until one of a number o
 382:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
 383:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__((always_inline)) __STATIC_INLINE void __WFI(void)
 384:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 385:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("wfi");
 386:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 387:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 388:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 389:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 390:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Wait For Event
 391:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Wait For Event is a hint instruction that permits the processor to enter
 392:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****     a low-power state until one of a number of events occurs.
 393:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
 394:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__((always_inline)) __STATIC_INLINE void __WFE(void)
 395:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 396:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("wfe");
 397:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 398:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 399:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 400:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 401:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Send Event
 402:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Send Event is a hint instruction. It causes an event to be signaled to the CPU.
 403:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
