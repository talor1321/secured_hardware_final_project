 407:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 408:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 409:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 410:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 411:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Instruction Synchronization Barrier
 412:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Instruction Synchronization Barrier flushes the pipeline in the processor,
 413:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****            so that all instructions following the ISB are fetched from cache or memory,
 414:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****            after the instruction has been completed.
 415:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
 416:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__((always_inline)) __STATIC_INLINE void __ISB(void)
 417:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 418:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("isb 0xF":::"memory");
 419:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 420:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 421:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 422:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 423:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Data Synchronization Barrier
 424:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Acts as a special kind of Data Memory Barrier.
 425:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****            It completes when all explicit memory accesses before this instruction complete.
 426:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
 427:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__((always_inline)) __STATIC_INLINE void __DSB(void)
 428:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 429:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("dsb 0xF":::"memory");
 430:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 431:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 432:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 433:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 434:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Data Memory Barrier
 435:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Ensures the apparent order of the explicit memory operations before
 436:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****            and after the instruction, without ensuring their completion.
 437:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
 438:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__((always_inline)) __STATIC_INLINE void __DMB(void)
 439:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 440:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("dmb 0xF":::"memory");
 441:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 442:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 443:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 444:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 445:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Reverse byte order (32 bit)
 446:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Reverses the byte order in integer value.
 447:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \param [in]    value  Value to reverse
 448:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \return               Reversed value
 449:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
 450:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__((always_inline)) __STATIC_INLINE uint32_t __REV(uint32_t value)
 451:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 452:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #if (__GNUC__ > 4) || (__GNUC__ == 4 && __GNUC_MINOR__ >= 5)
 453:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   return __builtin_bswap32(value);
 454:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #else
 455:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   uint32_t result;
 456:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 457:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("rev %0, %1" : __CMSIS_GCC_OUT_REG (result) : __CMSIS_GCC_USE_REG (value) );
 458:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   return(result);
 459:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #endif
 460:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 461:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 462:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 463:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 464:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Reverse byte order (16 bit)
 465:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Reverses the byte order in two unsigned short values.
 466:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \param [in]    value  Value to reverse
 467:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \return               Reversed value
 468:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
 469:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__((always_inline)) __STATIC_INLINE uint32_t __REV16(uint32_t value)
 470:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 471:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   uint32_t result;
 472:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 473:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("rev16 %0, %1" : __CMSIS_GCC_OUT_REG (result) : __CMSIS_GCC_USE_REG (value) );
 474:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   return(result);
 475:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 476:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 477:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 478:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 479:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Reverse byte order in signed short value
 480:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Reverses the byte order in a signed short value with sign extension to integer.
 481:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \param [in]    value  Value to reverse
 482:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \return               Reversed value
 483:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
 484:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__((always_inline)) __STATIC_INLINE int32_t __REVSH(int32_t value)
 485:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 486:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #if (__GNUC__ > 4) || (__GNUC__ == 4 && __GNUC_MINOR__ >= 8)
 487:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   return (short)__builtin_bswap16(value);
 488:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #else
 489:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   int32_t result;
 490:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 491:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("revsh %0, %1" : __CMSIS_GCC_OUT_REG (result) : __CMSIS_GCC_USE_REG (value) );
 492:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   return(result);
 493:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #endif
 494:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 495:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 496:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 497:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 498:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Rotate Right in unsigned value (32 bit)
 499:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Rotate Right (immediate) provides the value of the contents of a register rotated by a v
 500:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \param [in]    value  Value to rotate
 501:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \param [in]    value  Number of Bits to rotate
 502:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \return               Rotated value
 503:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  */
 504:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** __attribute__((always_inline)) __STATIC_INLINE uint32_t __ROR(uint32_t op1, uint32_t op2)
 505:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 506:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   return (op1 >> op2) | (op1 << (32U - op2));
 507:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 508:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 509:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 510:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 511:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   Breakpoint
 512:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details Causes the processor to enter Debug state.
 513:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****            Debug tools can use this to investigate system state when the instruction at a particula
