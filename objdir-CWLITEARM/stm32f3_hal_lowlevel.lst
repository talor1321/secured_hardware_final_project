 941:../../firmware/mcu/hal//stm32f3/stm32f3_hal_lowlevel.c ****   {
 942:../../firmware/mcu/hal//stm32f3/stm32f3_hal_lowlevel.c ****     /* Wait until TEACK flag is set */
