 336:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** {
 337:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #if (__FPU_PRESENT == 1U) && (__FPU_USED == 1U)
 338:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   /* Empty asm statement works as a scheduling barrier */
 339:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("");
 340:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("VMSR fpscr, %0" : : "r" (fpscr) : "vfpcc");
 341:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   __ASM volatile ("");
 342:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #endif
 343:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** }
 344:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 345:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #endif /* (__CORTEX_M == 0x04U) || (__CORTEX_M == 0x07U) */
 346:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 347:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 348:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 349:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /*@} end of CMSIS_Core_RegAccFunctions */
