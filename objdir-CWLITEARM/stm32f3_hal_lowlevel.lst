 357:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 358:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /* Define macros for porting to both thumb1 and thumb2.
 359:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  * For thumb1, use low register (r0-r7), specified by constraint "l"
 360:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****  * Otherwise, use general registers, specified by constraint "r" */
 361:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #if defined (__thumb__) && !defined (__thumb2__)
 362:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #define __CMSIS_GCC_OUT_REG(r) "=l" (r)
 363:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #define __CMSIS_GCC_USE_REG(r) "l" (r)
 364:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #else
 365:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #define __CMSIS_GCC_OUT_REG(r) "=r" (r)
 366:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #define __CMSIS_GCC_USE_REG(r) "r" (r)
 367:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** #endif
 368:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** 
 369:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h **** /**
 370:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \brief   No Operation
 371:../../firmware/mcu/hal//stm32f3/CMSIS/core/cmsis_gcc.h ****   \details No Operation does nothing. This instruction can be used for code alignment purposes.
