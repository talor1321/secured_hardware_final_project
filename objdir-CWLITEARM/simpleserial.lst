 179:../../firmware/mcu/hal/hal.h ****     #define HW_AES128_LoadKey(key);  for (uint8_t i = 0; i < 16; i++){ \
 180:../../firmware/mcu/hal/hal.h ****                                      AES_KEY = *(key+i); \
 181:../../firmware/mcu/hal/hal.h ****                                   }
 182:../../firmware/mcu/hal/hal.h **** 
 183:../../firmware/mcu/hal/hal.h ****     #define HW_AES128_Enc(pt);  for (uint8_t i = 0; i < 16; i++){ \
 184:../../firmware/mcu/hal/hal.h ****                                     AES_STATE = *(pt+i); \
 185:../../firmware/mcu/hal/hal.h ****                                 } \
 186:../../firmware/mcu/hal/hal.h ****                                   \
 187:../../firmware/mcu/hal/hal.h ****                                 AES_CTRL |= 1<<AES_REQUEST; \
 188:../../firmware/mcu/hal/hal.h ****                                   \
 189:../../firmware/mcu/hal/hal.h ****                                 /*Wait for done  */ \
 190:../../firmware/mcu/hal/hal.h ****                                 while ((AES_STATUS & (1<<AES_DONE)) == 0){ \
 191:../../firmware/mcu/hal/hal.h ****                                     ; \
 192:../../firmware/mcu/hal/hal.h ****                                 } \
 193:../../firmware/mcu/hal/hal.h ****                                   \
 194:../../firmware/mcu/hal/hal.h ****                                 for (uint8_t i = 0; i < 16; i++){ \
 195:../../firmware/mcu/hal/hal.h ****                                     *(pt+i) = AES_STATE; \
 196:../../firmware/mcu/hal/hal.h ****                                 }
