 360:../../firmware/mcu/simpleserial/simpleserial.c **** void simpleserial_get(void)
 361:../../firmware/mcu/simpleserial/simpleserial.c **** {
 362:../../firmware/mcu/simpleserial/simpleserial.c **** 	char ascii_buf[2*MAX_SS_LEN];
 363:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t data_buf[MAX_SS_LEN];
 364:../../firmware/mcu/simpleserial/simpleserial.c **** 	char c;
 365:../../firmware/mcu/simpleserial/simpleserial.c **** 
 366:../../firmware/mcu/simpleserial/simpleserial.c **** 	// Find which command we're receiving
 367:../../firmware/mcu/simpleserial/simpleserial.c **** 	c = getch();
 368:../../firmware/mcu/simpleserial/simpleserial.c **** 
 369:../../firmware/mcu/simpleserial/simpleserial.c **** 	int cmd;
 370:../../firmware/mcu/simpleserial/simpleserial.c **** 	for(cmd = 0; cmd < num_commands; cmd++)
 371:../../firmware/mcu/simpleserial/simpleserial.c **** 	{
 372:../../firmware/mcu/simpleserial/simpleserial.c **** 		if(commands[cmd].c == c)
 373:../../firmware/mcu/simpleserial/simpleserial.c **** 			break;
 374:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 375:../../firmware/mcu/simpleserial/simpleserial.c **** 
 376:../../firmware/mcu/simpleserial/simpleserial.c **** 	// If we didn't find a match, give up right away
 377:../../firmware/mcu/simpleserial/simpleserial.c **** 	if(cmd == num_commands)
 378:../../firmware/mcu/simpleserial/simpleserial.c **** 		return;
 379:../../firmware/mcu/simpleserial/simpleserial.c **** 
 380:../../firmware/mcu/simpleserial/simpleserial.c **** 	// If flag CMD_FLAG_LEN is set, the next byte indicates the sent length
 381:../../firmware/mcu/simpleserial/simpleserial.c **** 	if ((commands[cmd].flags & CMD_FLAG_LEN) != 0)
 382:../../firmware/mcu/simpleserial/simpleserial.c **** 	{
 383:../../firmware/mcu/simpleserial/simpleserial.c **** 		uint8_t l = 0;
 384:../../firmware/mcu/simpleserial/simpleserial.c **** 		char buff[2];
 385:../../firmware/mcu/simpleserial/simpleserial.c **** 		buff[0] = getch();
 386:../../firmware/mcu/simpleserial/simpleserial.c **** 		buff[1] = getch();
 387:../../firmware/mcu/simpleserial/simpleserial.c **** 		if (hex_decode(1, buff, &l))
 388:../../firmware/mcu/simpleserial/simpleserial.c **** 			return;
 389:../../firmware/mcu/simpleserial/simpleserial.c **** 		commands[cmd].len = l;
 390:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 391:../../firmware/mcu/simpleserial/simpleserial.c **** 
 392:../../firmware/mcu/simpleserial/simpleserial.c **** 	// Receive characters until we fill the ASCII buffer
 393:../../firmware/mcu/simpleserial/simpleserial.c **** 	for(int i = 0; i < 2*commands[cmd].len; i++)
 394:../../firmware/mcu/simpleserial/simpleserial.c **** 	{
 395:../../firmware/mcu/simpleserial/simpleserial.c **** 		c = getch();
 396:../../firmware/mcu/simpleserial/simpleserial.c **** 
 397:../../firmware/mcu/simpleserial/simpleserial.c **** 		// Check for early \n
 398:../../firmware/mcu/simpleserial/simpleserial.c **** 		if(c == '\n' || c == '\r')
 399:../../firmware/mcu/simpleserial/simpleserial.c **** 			return;
 400:../../firmware/mcu/simpleserial/simpleserial.c **** 
 401:../../firmware/mcu/simpleserial/simpleserial.c **** 		ascii_buf[i] = c;
 402:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 403:../../firmware/mcu/simpleserial/simpleserial.c **** 
 404:../../firmware/mcu/simpleserial/simpleserial.c **** 	// Assert that last character is \n or \r
 405:../../firmware/mcu/simpleserial/simpleserial.c **** 	c = getch();
 406:../../firmware/mcu/simpleserial/simpleserial.c **** 	if(c != '\n' && c != '\r')
 407:../../firmware/mcu/simpleserial/simpleserial.c **** 		return;
 408:../../firmware/mcu/simpleserial/simpleserial.c **** 
 409:../../firmware/mcu/simpleserial/simpleserial.c **** 	// ASCII buffer is full: convert to bytes
 410:../../firmware/mcu/simpleserial/simpleserial.c **** 	// Check for illegal characters here
 411:../../firmware/mcu/simpleserial/simpleserial.c **** 	if(hex_decode(commands[cmd].len, ascii_buf, data_buf))
 412:../../firmware/mcu/simpleserial/simpleserial.c **** 		return;
 413:../../firmware/mcu/simpleserial/simpleserial.c **** 
 414:../../firmware/mcu/simpleserial/simpleserial.c **** 	// Callback
 415:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t ret[1];
 416:../../firmware/mcu/simpleserial/simpleserial.c **** 	ret[0] = commands[cmd].fp(data_buf, commands[cmd].len);
 417:../../firmware/mcu/simpleserial/simpleserial.c **** 
 418:../../firmware/mcu/simpleserial/simpleserial.c **** 	// Acknowledge (if version is 1.1)
 419:../../firmware/mcu/simpleserial/simpleserial.c **** #if SS_VER == SS_VER_1_1
 420:../../firmware/mcu/simpleserial/simpleserial.c **** 	simpleserial_put('z', 1, ret);
 421:../../firmware/mcu/simpleserial/simpleserial.c **** #endif
 422:../../firmware/mcu/simpleserial/simpleserial.c **** }
