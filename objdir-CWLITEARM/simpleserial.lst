   7:../../firmware/mcu/simpleserial/simpleserial.c **** 
   8:../../firmware/mcu/simpleserial/simpleserial.c **** #define MAX_SS_CMDS 16
   9:../../firmware/mcu/simpleserial/simpleserial.c **** static int num_commands = 0;
  10:../../firmware/mcu/simpleserial/simpleserial.c **** 
  11:../../firmware/mcu/simpleserial/simpleserial.c **** #define MAX_SS_LEN 256
  12:../../firmware/mcu/simpleserial/simpleserial.c **** 
  13:../../firmware/mcu/simpleserial/simpleserial.c **** //#define SS_VER_1_0 0
  14:../../firmware/mcu/simpleserial/simpleserial.c **** //#define SS_VER_1_1 1
  15:../../firmware/mcu/simpleserial/simpleserial.c **** //#define SS_VER_2_0 2
  16:../../firmware/mcu/simpleserial/simpleserial.c **** 
  17:../../firmware/mcu/simpleserial/simpleserial.c **** 
  18:../../firmware/mcu/simpleserial/simpleserial.c **** // 0xA6 formerly 
  19:../../firmware/mcu/simpleserial/simpleserial.c **** #define CW_CRC 0x4D 
  20:../../firmware/mcu/simpleserial/simpleserial.c **** uint8_t ss_crc(uint8_t *buf, uint8_t len)
  21:../../firmware/mcu/simpleserial/simpleserial.c **** {
  22:../../firmware/mcu/simpleserial/simpleserial.c **** 	unsigned int k = 0;
  23:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t crc = 0x00;
  24:../../firmware/mcu/simpleserial/simpleserial.c **** 	while (len--) {
  25:../../firmware/mcu/simpleserial/simpleserial.c **** 		crc ^= *buf++;
  26:../../firmware/mcu/simpleserial/simpleserial.c **** 		for (k = 0; k < 8; k++) {
  27:../../firmware/mcu/simpleserial/simpleserial.c **** 			crc = crc & 0x80 ? (crc << 1) ^ CW_CRC: crc << 1;
  28:../../firmware/mcu/simpleserial/simpleserial.c **** 		}
  29:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
  30:../../firmware/mcu/simpleserial/simpleserial.c **** 	return crc;
  31:../../firmware/mcu/simpleserial/simpleserial.c **** 
  32:../../firmware/mcu/simpleserial/simpleserial.c **** }
  33:../../firmware/mcu/simpleserial/simpleserial.c **** 
  34:../../firmware/mcu/simpleserial/simpleserial.c **** // [B_STUFF, CMD, SCMD, LEN, B_STUFF, DATA..., CRC, TERM]
  35:../../firmware/mcu/simpleserial/simpleserial.c **** 
  36:../../firmware/mcu/simpleserial/simpleserial.c **** //#define SS_VER SS_VER_2_0
  37:../../firmware/mcu/simpleserial/simpleserial.c **** #if SS_VER == SS_VER_2_0
  38:../../firmware/mcu/simpleserial/simpleserial.c **** #error "SS_VER_2_0 is deprecated! Use SS_VER_2_1 instead."
  39:../../firmware/mcu/simpleserial/simpleserial.c **** #elif SS_VER == SS_VER_2_1
  40:../../firmware/mcu/simpleserial/simpleserial.c **** 
  41:../../firmware/mcu/simpleserial/simpleserial.c **** int hex_decode(int len, char* ascii_buf, uint8_t* data_buf)
  42:../../firmware/mcu/simpleserial/simpleserial.c **** {
  43:../../firmware/mcu/simpleserial/simpleserial.c **** 	for(int i = 0; i < len; i++)
  44:../../firmware/mcu/simpleserial/simpleserial.c **** 	{
  45:../../firmware/mcu/simpleserial/simpleserial.c **** 		char n_hi = ascii_buf[2*i];
  46:../../firmware/mcu/simpleserial/simpleserial.c **** 		char n_lo = ascii_buf[2*i+1];
  47:../../firmware/mcu/simpleserial/simpleserial.c **** 
  48:../../firmware/mcu/simpleserial/simpleserial.c **** 		if(n_lo >= '0' && n_lo <= '9')
  49:../../firmware/mcu/simpleserial/simpleserial.c **** 			data_buf[i] = n_lo - '0';
  50:../../firmware/mcu/simpleserial/simpleserial.c **** 		else if(n_lo >= 'A' && n_lo <= 'F')
  51:../../firmware/mcu/simpleserial/simpleserial.c **** 			data_buf[i] = n_lo - 'A' + 10;
  52:../../firmware/mcu/simpleserial/simpleserial.c **** 		else if(n_lo >= 'a' && n_lo <= 'f')
  53:../../firmware/mcu/simpleserial/simpleserial.c **** 			data_buf[i] = n_lo - 'a' + 10;
  54:../../firmware/mcu/simpleserial/simpleserial.c **** 		else
  55:../../firmware/mcu/simpleserial/simpleserial.c **** 			return 1;
  56:../../firmware/mcu/simpleserial/simpleserial.c **** 
  57:../../firmware/mcu/simpleserial/simpleserial.c **** 		if(n_hi >= '0' && n_hi <= '9')
  58:../../firmware/mcu/simpleserial/simpleserial.c **** 			data_buf[i] |= (n_hi - '0') << 4;
  59:../../firmware/mcu/simpleserial/simpleserial.c **** 		else if(n_hi >= 'A' && n_hi <= 'F')
  60:../../firmware/mcu/simpleserial/simpleserial.c **** 			data_buf[i] |= (n_hi - 'A' + 10) << 4;
  61:../../firmware/mcu/simpleserial/simpleserial.c **** 		else if(n_hi >= 'a' && n_hi <= 'f')
  62:../../firmware/mcu/simpleserial/simpleserial.c **** 			data_buf[i] |= (n_hi - 'a' + 10) << 4;
  63:../../firmware/mcu/simpleserial/simpleserial.c **** 		else
  64:../../firmware/mcu/simpleserial/simpleserial.c **** 			return 1;
  65:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
  66:../../firmware/mcu/simpleserial/simpleserial.c **** 
  67:../../firmware/mcu/simpleserial/simpleserial.c **** 	return 0;
  68:../../firmware/mcu/simpleserial/simpleserial.c **** }
  69:../../firmware/mcu/simpleserial/simpleserial.c **** 
  70:../../firmware/mcu/simpleserial/simpleserial.c **** typedef struct ss_cmd
  71:../../firmware/mcu/simpleserial/simpleserial.c **** {
  72:../../firmware/mcu/simpleserial/simpleserial.c **** 	char c;
  73:../../firmware/mcu/simpleserial/simpleserial.c **** 	unsigned int len;
  74:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t (*fp)(uint8_t, uint8_t, uint8_t, uint8_t *);
  75:../../firmware/mcu/simpleserial/simpleserial.c **** } ss_cmd;
  76:../../firmware/mcu/simpleserial/simpleserial.c **** static ss_cmd commands[MAX_SS_CMDS];
  77:../../firmware/mcu/simpleserial/simpleserial.c **** 
  78:../../firmware/mcu/simpleserial/simpleserial.c **** void ss_puts(char *x)
  79:../../firmware/mcu/simpleserial/simpleserial.c **** {
  80:../../firmware/mcu/simpleserial/simpleserial.c **** 	do {
  81:../../firmware/mcu/simpleserial/simpleserial.c **** 		putch(*x);
  82:../../firmware/mcu/simpleserial/simpleserial.c **** 	} while (*++x);
  83:../../firmware/mcu/simpleserial/simpleserial.c **** }
  84:../../firmware/mcu/simpleserial/simpleserial.c **** 
  85:../../firmware/mcu/simpleserial/simpleserial.c **** #define FRAME_BYTE 0x00
  86:../../firmware/mcu/simpleserial/simpleserial.c **** 
  87:../../firmware/mcu/simpleserial/simpleserial.c **** uint8_t check_version(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *data)
  88:../../firmware/mcu/simpleserial/simpleserial.c **** {
  89:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t ver = SS_VER;
  90:../../firmware/mcu/simpleserial/simpleserial.c **** 	simpleserial_put('r', 1, &ver);
  91:../../firmware/mcu/simpleserial/simpleserial.c **** 	return SS_ERR_OK;
  92:../../firmware/mcu/simpleserial/simpleserial.c **** }
  93:../../firmware/mcu/simpleserial/simpleserial.c **** 
  94:../../firmware/mcu/simpleserial/simpleserial.c **** uint8_t ss_get_commands(uint8_t cmd, uint8_t scmd, uint8_t len, uint8_t *data)
  95:../../firmware/mcu/simpleserial/simpleserial.c **** {
  96:../../firmware/mcu/simpleserial/simpleserial.c ****     uint8_t cmd_chars[MAX_SS_CMDS];
  97:../../firmware/mcu/simpleserial/simpleserial.c ****     for (uint8_t i = 0; i < (num_commands & 0xFF); i++) {
  98:../../firmware/mcu/simpleserial/simpleserial.c ****         cmd_chars[i] = commands[i].c;
  99:../../firmware/mcu/simpleserial/simpleserial.c ****     }
 100:../../firmware/mcu/simpleserial/simpleserial.c **** 
 101:../../firmware/mcu/simpleserial/simpleserial.c ****     simpleserial_put('r', num_commands & 0xFF, (void *)cmd_chars);
 102:../../firmware/mcu/simpleserial/simpleserial.c ****     return 0x00;
 103:../../firmware/mcu/simpleserial/simpleserial.c **** 
 104:../../firmware/mcu/simpleserial/simpleserial.c **** }
 105:../../firmware/mcu/simpleserial/simpleserial.c **** 
 106:../../firmware/mcu/simpleserial/simpleserial.c **** uint8_t stuff_data(uint8_t *buf, uint8_t len)
 107:../../firmware/mcu/simpleserial/simpleserial.c **** {
 108:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t i = 1;
 109:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t last = 0;
 110:../../firmware/mcu/simpleserial/simpleserial.c **** 	for (; i < len; i++) {
 111:../../firmware/mcu/simpleserial/simpleserial.c **** 		if (buf[i] == FRAME_BYTE) {
 112:../../firmware/mcu/simpleserial/simpleserial.c **** 			buf[last] = i - last;
 113:../../firmware/mcu/simpleserial/simpleserial.c **** 			last = i;
 114:../../firmware/mcu/simpleserial/simpleserial.c **** 		}
 115:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 116:../../firmware/mcu/simpleserial/simpleserial.c **** 	return 0x00;
 117:../../firmware/mcu/simpleserial/simpleserial.c **** }
 118:../../firmware/mcu/simpleserial/simpleserial.c **** 
 119:../../firmware/mcu/simpleserial/simpleserial.c **** uint8_t unstuff_data(uint8_t *buf, uint8_t len)
 120:../../firmware/mcu/simpleserial/simpleserial.c **** {
 121:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t next = buf[0];
 122:../../firmware/mcu/simpleserial/simpleserial.c **** 	buf[0] = 0x00;
 123:../../firmware/mcu/simpleserial/simpleserial.c **** 	//len -= 1;
 124:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t tmp = next;
 125:../../firmware/mcu/simpleserial/simpleserial.c **** 	while ((next < len) && tmp != 0) {
 126:../../firmware/mcu/simpleserial/simpleserial.c **** 		tmp = buf[next];
 127:../../firmware/mcu/simpleserial/simpleserial.c **** 		buf[next] = FRAME_BYTE;
 128:../../firmware/mcu/simpleserial/simpleserial.c **** 		next += tmp;
 129:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 130:../../firmware/mcu/simpleserial/simpleserial.c **** 	return next;
 131:../../firmware/mcu/simpleserial/simpleserial.c **** }
 132:../../firmware/mcu/simpleserial/simpleserial.c **** 
 133:../../firmware/mcu/simpleserial/simpleserial.c **** // Set up the SimpleSerial module by preparing internal commands
 134:../../firmware/mcu/simpleserial/simpleserial.c **** // This just adds the "v" command for now...
 135:../../firmware/mcu/simpleserial/simpleserial.c **** void simpleserial_init()
 136:../../firmware/mcu/simpleserial/simpleserial.c **** {
 137:../../firmware/mcu/simpleserial/simpleserial.c **** 	simpleserial_addcmd('v', 0, check_version);
 138:../../firmware/mcu/simpleserial/simpleserial.c ****     simpleserial_addcmd('w', 0, ss_get_commands);
 139:../../firmware/mcu/simpleserial/simpleserial.c **** }
 140:../../firmware/mcu/simpleserial/simpleserial.c **** 
 141:../../firmware/mcu/simpleserial/simpleserial.c **** int simpleserial_addcmd(char c, unsigned int len, uint8_t (*fp)(uint8_t, uint8_t, uint8_t, uint8_t*
 142:../../firmware/mcu/simpleserial/simpleserial.c **** {
 143:../../firmware/mcu/simpleserial/simpleserial.c **** 	if(num_commands >= MAX_SS_CMDS) {
 144:../../firmware/mcu/simpleserial/simpleserial.c **** 		putch('a');
 145:../../firmware/mcu/simpleserial/simpleserial.c **** 		return 1;
 146:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 147:../../firmware/mcu/simpleserial/simpleserial.c **** 
 148:../../firmware/mcu/simpleserial/simpleserial.c **** 	if(len >= MAX_SS_LEN) {
 149:../../firmware/mcu/simpleserial/simpleserial.c **** 		putch('b');
 150:../../firmware/mcu/simpleserial/simpleserial.c **** 		return 1;
 151:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 152:../../firmware/mcu/simpleserial/simpleserial.c **** 
 153:../../firmware/mcu/simpleserial/simpleserial.c **** 	commands[num_commands].c   = c;
 154:../../firmware/mcu/simpleserial/simpleserial.c **** 	commands[num_commands].len = len;
 155:../../firmware/mcu/simpleserial/simpleserial.c **** 	commands[num_commands].fp  = fp;
 156:../../firmware/mcu/simpleserial/simpleserial.c **** 	num_commands++;
 157:../../firmware/mcu/simpleserial/simpleserial.c **** 
 158:../../firmware/mcu/simpleserial/simpleserial.c **** 	return 0;
 159:../../firmware/mcu/simpleserial/simpleserial.c **** }
 160:../../firmware/mcu/simpleserial/simpleserial.c **** 
 161:../../firmware/mcu/simpleserial/simpleserial.c **** void simpleserial_get(void)
 162:../../firmware/mcu/simpleserial/simpleserial.c **** {
 163:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t data_buf[MAX_SS_LEN];
 164:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t err = 0;
 165:../../firmware/mcu/simpleserial/simpleserial.c **** 
 166:../../firmware/mcu/simpleserial/simpleserial.c **** 	for (int i = 0; i < 4; i++) {
 167:../../firmware/mcu/simpleserial/simpleserial.c **** 		data_buf[i] = getch(); //PTR, cmd, scmd, len
 168:../../firmware/mcu/simpleserial/simpleserial.c **** 		if (data_buf[i] == FRAME_BYTE) {
 169:../../firmware/mcu/simpleserial/simpleserial.c **** 			err = SS_ERR_FRAME_BYTE;
 170:../../firmware/mcu/simpleserial/simpleserial.c **** 			goto ERROR;
 171:../../firmware/mcu/simpleserial/simpleserial.c **** 		}
 172:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 173:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t next_frame = unstuff_data(data_buf, 4);
 174:../../firmware/mcu/simpleserial/simpleserial.c **** 
 175:../../firmware/mcu/simpleserial/simpleserial.c **** 	// check for valid command
 176:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t c = 0;
 177:../../firmware/mcu/simpleserial/simpleserial.c **** 	for(c = 0; c < num_commands; c++)
 178:../../firmware/mcu/simpleserial/simpleserial.c **** 	{
 179:../../firmware/mcu/simpleserial/simpleserial.c **** 		if(commands[c].c == data_buf[1])
 180:../../firmware/mcu/simpleserial/simpleserial.c **** 			break;
 181:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 182:../../firmware/mcu/simpleserial/simpleserial.c **** 
 183:../../firmware/mcu/simpleserial/simpleserial.c **** 	if (c == num_commands) {
 184:../../firmware/mcu/simpleserial/simpleserial.c **** 		err = SS_ERR_CMD;
 185:../../firmware/mcu/simpleserial/simpleserial.c **** 		goto ERROR;
 186:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 187:../../firmware/mcu/simpleserial/simpleserial.c **** 
 188:../../firmware/mcu/simpleserial/simpleserial.c **** 	//check that next frame not beyond end of message
 189:../../firmware/mcu/simpleserial/simpleserial.c **** 	// account for cmd, scmd, len, data, crc, end of frame
 190:../../firmware/mcu/simpleserial/simpleserial.c **** 	if ((data_buf[3] + 5) < next_frame) {
 191:../../firmware/mcu/simpleserial/simpleserial.c **** 		err = SS_ERR_LEN;
 192:../../firmware/mcu/simpleserial/simpleserial.c **** 		goto ERROR;
 193:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 194:../../firmware/mcu/simpleserial/simpleserial.c **** 
 195:../../firmware/mcu/simpleserial/simpleserial.c **** 	// read in data
 196:../../firmware/mcu/simpleserial/simpleserial.c **** 	// eq to len + crc + frame end
 197:../../firmware/mcu/simpleserial/simpleserial.c **** 	int i = 4;
 198:../../firmware/mcu/simpleserial/simpleserial.c **** 	for (; i < data_buf[3] + 5; i++) {
 199:../../firmware/mcu/simpleserial/simpleserial.c **** 		data_buf[i] = getch();
 200:../../firmware/mcu/simpleserial/simpleserial.c **** 		if (data_buf[i] == FRAME_BYTE) {
 201:../../firmware/mcu/simpleserial/simpleserial.c **** 			err = SS_ERR_FRAME_BYTE;
 202:../../firmware/mcu/simpleserial/simpleserial.c **** 			goto ERROR;
 203:../../firmware/mcu/simpleserial/simpleserial.c **** 		}
 204:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 205:../../firmware/mcu/simpleserial/simpleserial.c **** 
 206:../../firmware/mcu/simpleserial/simpleserial.c **** 	//check that final byte is the FRAME_BYTE
 207:../../firmware/mcu/simpleserial/simpleserial.c **** 	data_buf[i] = getch();
 208:../../firmware/mcu/simpleserial/simpleserial.c **** 	if (data_buf[i] != FRAME_BYTE) {
 209:../../firmware/mcu/simpleserial/simpleserial.c **** 		err = SS_ERR_LEN;
 210:../../firmware/mcu/simpleserial/simpleserial.c **** 		goto ERROR;
 211:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 212:../../firmware/mcu/simpleserial/simpleserial.c **** 
 213:../../firmware/mcu/simpleserial/simpleserial.c **** 	//fully unstuff data now
 214:../../firmware/mcu/simpleserial/simpleserial.c **** 	unstuff_data(data_buf + next_frame, i - next_frame + 1);
 215:../../firmware/mcu/simpleserial/simpleserial.c **** 
 216:../../firmware/mcu/simpleserial/simpleserial.c **** 	//calc crc excluding original frame offset and frame end and crc
 217:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t crc = ss_crc(data_buf+1, i-2);
 218:../../firmware/mcu/simpleserial/simpleserial.c **** 	if (crc != data_buf[i-1]) {
 219:../../firmware/mcu/simpleserial/simpleserial.c **** 		err = SS_ERR_CRC;
 220:../../firmware/mcu/simpleserial/simpleserial.c **** 		goto ERROR;
 221:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 222:../../firmware/mcu/simpleserial/simpleserial.c **** 
 223:../../firmware/mcu/simpleserial/simpleserial.c **** 	err = commands[c].fp(data_buf[1], data_buf[2], data_buf[3], data_buf+4);
 224:../../firmware/mcu/simpleserial/simpleserial.c **** 
 225:../../firmware/mcu/simpleserial/simpleserial.c **** ERROR:
 226:../../firmware/mcu/simpleserial/simpleserial.c **** 	simpleserial_put('e', 0x01, &err);
 227:../../firmware/mcu/simpleserial/simpleserial.c **** 	return;
 228:../../firmware/mcu/simpleserial/simpleserial.c **** }
 229:../../firmware/mcu/simpleserial/simpleserial.c **** 
 230:../../firmware/mcu/simpleserial/simpleserial.c **** void simpleserial_put(char c, uint8_t size, uint8_t* output)
 231:../../firmware/mcu/simpleserial/simpleserial.c **** {
 232:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t data_buf[MAX_SS_LEN];
 233:../../firmware/mcu/simpleserial/simpleserial.c **** 	data_buf[0] = 0x00;
 234:../../firmware/mcu/simpleserial/simpleserial.c **** 	data_buf[1] = c;
 235:../../firmware/mcu/simpleserial/simpleserial.c **** 	data_buf[2] = size;
 236:../../firmware/mcu/simpleserial/simpleserial.c **** 	int i = 0;
 237:../../firmware/mcu/simpleserial/simpleserial.c **** 	for (; i < size; i++) {
 238:../../firmware/mcu/simpleserial/simpleserial.c **** 		data_buf[i + 3] = output[i];
 239:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 240:../../firmware/mcu/simpleserial/simpleserial.c **** 	data_buf[i + 3] = ss_crc(data_buf+1, size+2);
 241:../../firmware/mcu/simpleserial/simpleserial.c **** 	data_buf[i + 4] = 0x00;
 242:../../firmware/mcu/simpleserial/simpleserial.c **** 	stuff_data(data_buf, i + 5);
 243:../../firmware/mcu/simpleserial/simpleserial.c **** 	for (int i = 0; i < size + 5; i++) {
 244:../../firmware/mcu/simpleserial/simpleserial.c **** 		putch(data_buf[i]);
 245:../../firmware/mcu/simpleserial/simpleserial.c **** 	}
 246:../../firmware/mcu/simpleserial/simpleserial.c **** }
 247:../../firmware/mcu/simpleserial/simpleserial.c **** 
 248:../../firmware/mcu/simpleserial/simpleserial.c **** 
 249:../../firmware/mcu/simpleserial/simpleserial.c **** #else
 250:../../firmware/mcu/simpleserial/simpleserial.c **** 
 251:../../firmware/mcu/simpleserial/simpleserial.c **** typedef struct ss_cmd
 252:../../firmware/mcu/simpleserial/simpleserial.c **** {
 253:../../firmware/mcu/simpleserial/simpleserial.c **** 	char c;
 254:../../firmware/mcu/simpleserial/simpleserial.c **** 	unsigned int len;
 255:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t (*fp)(uint8_t*, uint8_t);
 256:../../firmware/mcu/simpleserial/simpleserial.c **** 	uint8_t flags;
 257:../../firmware/mcu/simpleserial/simpleserial.c **** } ss_cmd;
